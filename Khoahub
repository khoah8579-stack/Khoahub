-- Hàm tạo TextBox mẫu
local function setupInput(box, placeholder, defaultText)
    box.Parent = Frame
    box.Size = UDim2.new(0.9, 0, 0, 35)
    box.PlaceholderText = placeholder
    box.Text = defaultText
    box.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    box.TextColor3 = Color3.new(1, 1, 0)
    box.Font = Enum.Font.SourceSans
    box.TextSize = 14
end

setupInput(SkillInput, "Nhập tên chiêu...", "Thai Cuc Cuu Cung")
setupInput(AmountInput, "Số lượng spam (Ví dụ: 30)", "30")
AmountInput.ClearTextOnFocus = false -- Không xóa số khi bấm vào

local function setupBtn(btn, text, color)
    btn.Parent = Frame
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    btn.BorderSizePixel = 0
end

setupBtn(SkillBtn, "BẮT ĐẦU SPAM", Color3.fromRGB(120, 0, 120))
setupBtn(FishBtn, "TEST: Instant Fish", Color3.fromRGB(0, 85, 127))
setupBtn(SellBtn, "TEST: Remote Sell", Color3.fromRGB(0, 120, 0))

--- LOGIC TEST ---

-- 1. Logic Spam Chiêu (Lấy cả Tên và Số lượng)
SkillBtn.MouseButton1Click:Connect(function()
    local skillName = SkillInput.Text
    local amount = tonumber(AmountInput.Text) -- Chuyển chữ sang số
    
    local char = game.Players.LocalPlayer.Character
    local tool = char and char:FindFirstChild("C\225\186\167n C\195\162u")
    
    -- Kiểm tra lỗi nhập liệu
    if not amount or amount <= 0 then
        warn("Lỗi: Số lượng spam không hợp lệ!")
        return
    end

    if tool and tool:FindFirstChild("Handle") and tool.Handle:FindFirstChild("Hook") then
        print(">>> ĐANG SPAM: " .. skillName .. " [" .. amount .. " lần]")
        
        for i = 1, amount do
            task.spawn(function()
                game:GetService("ReplicatedStorage").Event.SkillEvent:FireServer(skillName, tool.Handle.Hook)
            end)
        end
        warn(">>> Hoàn tất gửi " .. amount .. " yêu cầu!")
    else
        warn("Lỗi: Không tìm thấy vật phẩm hợp lệ!")
    end
end)

-- 2. Test Instant Fish
FishBtn.MouseButton1Click:Connect(function()
    local char = game.Players.LocalPlayer.Character
    local tool = char and char:FindFirstChild("C\225\186\167n C\195\162u")
    if tool then
        local args = {
            tool:WaitForChild("Handle"),
            tool.Fish:WaitForChild("DoneFishEvent"),
            tool.Fish:WaitForChild("StunBackpackEvent")
        }
        game:GetService("ReplicatedStorage").Event.FishEvent:FireServer(unpack(args))
    end
end)

-- 3. Test Remote Sell
SellBtn.MouseButton1Click:Connect(function()
    game:GetService("ReplicatedStorage").Event.SellFishEvent:FireServer()
end)
